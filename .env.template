# ─────────────────────────────────────────────────────────────────────────────
# Currotter — Environment Variables Template
# Copy ke .env lalu isi nilainya sebelum menjalankan aplikasi.
# ─────────────────────────────────────────────────────────────────────────────

# ── DigitalOcean Spaces ───────────────────────────────────────────────────────
# Object storage S3-compatible untuk menyimpan foto selama proses kurasi.
# Buat bucket di: https://cloud.digitalocean.com/spaces
DO_SPACES_KEY=your_spaces_access_key
DO_SPACES_SECRET=your_spaces_secret_key
DO_SPACES_ENDPOINT=nyc3.digitaloceanspaces.com
DO_SPACES_BUCKET=your_bucket_name

# ── DigitalOcean Gradient AI ──────────────────────────────────────────────────
# API key untuk vision model GPT-4.1-mini (aesthetic scoring).
# Dapatkan di: https://cloud.digitalocean.com/gen-ai
GRADIENT_API_KEY=your_gradient_api_key

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# - Di Replit: otomatis terisi via database provisioning.
# - Di server lain: format postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Session ───────────────────────────────────────────────────────────────────
# Secret acak min. 32 karakter untuk mengenkripsi cookie session.
# Generate baru dengan:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_random_session_secret_min_32_chars

# ── Autentikasi ───────────────────────────────────────────────────────────────
# Aplikasi ini menggunakan Replit Auth (OpenID Connect) secara default.
# Variabel di bawah ini diisi OTOMATIS oleh Replit — tidak perlu diisi manual:
#   REPL_ID       (auto-set by Replit)
#   ISSUER_URL    (auto-set by Replit, default: https://replit.com/oidc)
#
# Untuk deploy di luar Replit (DigitalOcean, VPS), autentikasi perlu diganti.
# Lihat panduan migrasi di: docs/deploy-digitalocean.md — Bagian Authentication.

# ── Google Drive Export ───────────────────────────────────────────────────────
# Diperlukan agar user bisa export foto ke Google Drive mereka sendiri.
# Setiap user akan diminta otorisasi Google saat pertama kali klik "Save to Drive".
# Tidak ada refresh token yang disimpan di server — hanya access token per-sesi.
#
# Cara setup (2 menit):
#   1. Buka https://console.cloud.google.com → pilih atau buat project
#   2. APIs & Services → Enable APIs → aktifkan "Google Drive API"
#   3. APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client IDs
#   4. Application type: Web application
#   5. Authorized redirect URIs: https://YOUR_DOMAIN/api/google/callback
#   6. Salin Client ID dan Client Secret ke bawah
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
