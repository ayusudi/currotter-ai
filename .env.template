# ─────────────────────────────────────────────────────────────────────────────
# Currotter — Environment Variables Template
# Copy ke .env lalu isi nilainya sebelum menjalankan aplikasi.
# ─────────────────────────────────────────────────────────────────────────────

# ── DigitalOcean Spaces ───────────────────────────────────────────────────────
# Object storage S3-compatible untuk menyimpan foto selama proses kurasi.
# Buat bucket di: https://cloud.digitalocean.com/spaces
DO_SPACES_KEY=your_spaces_access_key
DO_SPACES_SECRET=your_spaces_secret_key
DO_SPACES_ENDPOINT=nyc3.digitaloceanspaces.com
DO_SPACES_BUCKET=your_bucket_name

# ── DigitalOcean Gradient AI ──────────────────────────────────────────────────
# API key untuk vision model GPT-4.1-mini (aesthetic scoring).
# Dapatkan di: https://cloud.digitalocean.com/gen-ai
GRADIENT_API_KEY=your_gradient_api_key

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# - Di Replit: otomatis terisi via database provisioning.
# - Di server lain: format postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Session ───────────────────────────────────────────────────────────────────
# Secret acak min. 32 karakter untuk enkripsi cookie session.
# Generate baru dengan:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_random_session_secret_min_32_chars

# ── Autentikasi ───────────────────────────────────────────────────────────────
# Aplikasi mendukung dua provider autentikasi — pilih salah satu:
#
# OPSI A: Replit Auth (default, hanya untuk development di dalam Replit)
#   Variabel REPL_ID dan ISSUER_URL diisi OTOMATIS oleh Replit.
#   Tidak perlu diisi di sini.
#
# OPSI B: Auth0 (untuk deploy di luar Replit — DigitalOcean, VPS, dll)
#   Bila AUTH0_DOMAIN diisi, aplikasi otomatis pakai Auth0.
#   Daftar gratis di https://auth0.com → Applications → Create App (Regular Web App)
#   Tambahkan Callback URL: https://YOUR_DOMAIN/api/callback
#   Tambahkan Logout URL:   https://YOUR_DOMAIN
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret

# ── Google Drive Export ───────────────────────────────────────────────────────
# Diperlukan agar user bisa export foto ke Google Drive mereka sendiri.
# Setiap user diminta otorisasi Google saat pertama kali klik "Save to Drive".
# Tidak ada refresh token yang disimpan di server (access_type: online).
#
# Cara setup (5 menit):
#   1. Buka https://console.cloud.google.com → pilih atau buat project
#   2. APIs & Services → Library → aktifkan "Google Drive API"
#   3. APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client IDs
#   4. Application type: Web application
#   5. Authorized redirect URIs: https://YOUR_DOMAIN/api/google/callback
#   6. Salin Client ID dan Client Secret ke bawah
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
